# TradingAgents-CN phase 1 runtime env reference
# 实际运行时建议将这些变量写入仓库根目录 .env，
# compose 会通过 env_file: ../.env 注入到 ta_backend 容器。

DOCKER_CONTAINER=true
TZ=Asia/Shanghai

# Shared infra from docker/compose.parallel.yaml
MONGODB_ENABLED=true
MONGODB_HOST=fq_mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DATABASE=tradingagents_cn
MONGODB_DATABASE_NAME=tradingagents_cn
MONGODB_AUTH_SOURCE=admin
MONGODB_URL=mongodb://fq_mongodb:27017/tradingagents_cn
MONGO_URI=mongodb://fq_mongodb:27017/tradingagents_cn
MONGODB_CONNECTION_STRING=mongodb://fq_mongodb:27017/tradingagents_cn
USE_MONGODB_STORAGE=true

REDIS_ENABLED=true
REDIS_HOST=fq_redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=8
REDIS_URL=redis://fq_redis:6379/8

TA_USE_APP_CACHE=true
TRADINGAGENTS_LOG_DIR=/app/logs
TRADINGAGENTS_LOG_FILE=/app/logs/tradingagents.log
LOG_FILE=/app/logs/tradingagents.log
TRADINGAGENTS_DATA_DIR=/app/data
TRADINGAGENTS_CACHE_DIR=/app/data/cache
TRADINGAGENTS_SESSIONS_DIR=/app/data/sessions
TRADINGAGENTS_LOGS_DIR=/app/data/logs
TRADINGAGENTS_CONFIG_DIR=/app/data/config
TRADINGAGENTS_TEMP_DIR=/app/data/temp
TRADINGAGENTS_RESULTS_DIR=/app/data/analysis_results

# LLM / data-provider credentials
# 至少配置一个可用 LLM Key，否则无法完成股票分析推理。
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
TUSHARE_TOKEN=

# Optional upstream feature flags
SYNC_STOCK_BASICS_ENABLED=true
QUOTES_INGEST_ENABLED=true
QUOTES_BACKFILL_ON_STARTUP=true
QUOTES_BACKFILL_ON_OFFHOURS=true
TUSHARE_UNIFIED_ENABLED=false
AKSHARE_UNIFIED_ENABLED=false
BAOSTOCK_UNIFIED_ENABLED=false
NEWS_SYNC_ENABLED=false
