.stock-control-body
  display flex
  flex 1 1 auto
  flex-direction column
  gap 12px
  min-width 0
  min-height 0
  overflow hidden

.stock-control-toolbar
  flex 0 0 auto

.stock-control-summary
  justify-content flex-start

.stock-control-grid
  display grid
  grid-template-columns minmax(0, 0.84fr) minmax(0, 1.32fr) minmax(0, 0.84fr)
  gap 12px
  flex 1 1 auto
  min-width 0
  min-height 0
.stock-control-panel
  min-width 0
  min-height 0

.stock-control-panel__table
  display flex
  flex 1 1 auto
  flex-direction column
  min-width 0
  min-height 0
  overflow hidden

@media (max-width: 1440px)
  .stock-control-grid
    grid-template-columns minmax(0, 0.9fr) minmax(0, 1.1fr)
    overflow hidden

  .stock-control-grid > :last-child
    grid-column 1 / -1

@media (max-width: 960px)
  .stock-control-body
    overflow-x hidden
    overflow-y auto

  .stock-control-grid
    grid-template-columns 1fr
    grid-auto-rows minmax(360px, auto)

  .stock-control-grid > :last-child
    grid-column auto
