.stock-control-shell
  display flex
  flex-direction column
  height 100vh
  height 100dvh
  overflow hidden
  background #f5f7fa

.stock-control-body
  display flex
  flex 1 1 auto
  min-height 0
  overflow hidden
  padding 12px 16px 16px

.stock-control-grid
  display grid
  grid-template-columns repeat(3, minmax(320px, 1fr))
  gap 12px
  flex 1 1 auto
  min-height 0
  overflow hidden

.panel-card
  display flex
  flex-direction column
  min-height 0
  overflow hidden
  padding 12px
  background #fff
  border 1px solid #ebeef5
  border-radius 8px

.panel-card-header
  display flex
  align-items center
  justify-content space-between
  margin-bottom 8px
  font-size 15px
  font-weight 600
  color #303133

.panel-table
  display flex
  flex 1 1 auto
  min-height 0
  overflow hidden

@media (max-width: 1440px)
  .stock-control-grid
    grid-template-columns repeat(2, minmax(280px, 1fr))
    overflow auto

  .stock-control-grid > :last-child
    grid-column 1 / -1

@media (max-width: 960px)
  .stock-control-body
    overflow auto

  .stock-control-grid
    grid-template-columns 1fr
    grid-auto-rows minmax(360px, auto)

  .stock-control-grid > :last-child
    grid-column auto
