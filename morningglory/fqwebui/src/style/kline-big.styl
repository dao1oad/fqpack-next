.kline-big-main {
    position absolute
    left: 0;
    right: 0
    bottom: 0
    top: 0;
    width: 100%
    height: 100%;
    overflow hidden
    display: flex
    flex-direction column
    min-height 0

    background: #12161c

    .primary-button {
        background #12161c
    }

    .primary-yellow {
        color: #FFCC08
    }

    .up-red {
        color: #D04949
    }

    .primary-color {
        color: white
    }
    color: white

    .input-form .el-button {
        background-color: #12161c !important;
        border: 1px solid rgba(127, 127, 122, .2) !important;
    }
    .input-form .el-button:not(.el-button--primary):not(.el-button--success):not(.el-button--danger) {
        color: white !important;
    }
    .input-form .el-button:hover, .input-form .el-button:focus {
        background-color: #262a30 !important;
        border-color: rgba(127, 127, 122, .5) !important;
    }

    //输入框
    .el-input__wrapper {
        background-color: #12161c !important;
        box-shadow: none !important;
        border: 1px solid rgba(127, 127, 122, .2) !important;
    }

    .el-input__inner {
        background-color: transparent !important;
        color: white !important;
    }

    .el-input__inner::placeholder {
        color: #888 !important;
    }

    .el-input.is-disabled .el-input__inner {
        background-color: #12161c !important;
        border: 1px solid rgba(127, 127, 122, .2) !important;
        color: #666 !important;
    }

    .el-form-item__label {
        color: white
    }

    .kline-header-main {
        flex 0 0 auto
        min-height 48px
        padding 6px 8px
        box-sizing border-box
    }

    .input-form {
        margin: 0;
        position: static;
        width: 100%;
        min-height: 36px;
        flex-wrap wrap
    }

    .echarts-item-big {
        flex 1
        min-height 0
        width: 100%;
        margin-bottom 0px;
        display flex
    }

    #main {
        width 100%
        height 100%
    }
}

