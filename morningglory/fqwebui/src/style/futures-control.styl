.future-control-main {
    padding 10px;
    
    .up-red {
        color: #D04949
    }

    .down-green {
        color: #279D61
    }

    .zero-gray {
        color: #606266
    }

    .primary-yellow {
        color: #FFCC08
    }

    .primary-button {
        background #12161c
    }

    .el-divider {
        position: relative;
        background: rgba(127, 127, 122, .2);
    }

    h1 {
        text-align center
    }

    .form-input {
        width: 100px;
    }

    .el-input.is-disabled .el-input__inner {
        color: #D04949
    }

    .select-input {
        width: 80px;
    }

    .prejudge-form {
        text-align: center;
        margin-bottom: 10px;
    }

    .prejudge-input {
        width: 100%;
        line-height: 30px;
        height: 30px;
        background-color: #12161c;
        border: 1px solid rgba(127, 127, 122, .2);
    }
}
