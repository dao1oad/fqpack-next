# FreshQuant 宿主机运行时示例环境文件
#
# 适用场景：
# - Docker 并行模式下，Mongo 使用 fq_mongodb（宿主机端口 27027）
# - broker / xtdata producer / xtdata consumer 仍运行在 Windows 宿主机
#
# 说明：
# - Redis 当前仍指向宿主机 6379
# - 若后续按 RFC 0009 切换到项目内 .venv，只需保留本文件中的 Mongo/Redis 配置，Python 路径改 supervisor 模板

FQ_PACK_DIR=D:/fqpack
FQ_DATA_DIR=D:/fqdata

FRESHQUANT_MONGODB__HOST=127.0.0.1
FRESHQUANT_MONGODB__PORT=27027
FRESHQUANT_MONGODB__DB=freshquant

FRESHQUANT_REDIS__HOST=127.0.0.1
FRESHQUANT_REDIS__PORT=6379
FRESHQUANT_REDIS__DB=1

FRESHQUANT_TDX__HQ__ENDPOINT=http://127.0.0.1:15001

PYTHONUTF8=1
PYTHONLEGACYWINDOWSSTDIO=1
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost
