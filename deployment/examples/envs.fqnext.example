# FreshQuant 宿主机运行时示例环境文件
#
# 适用场景：
# - Docker 并行模式下，Mongo 使用 fq_mongodb（宿主机端口 27027）
# - broker / xtdata producer / xtdata consumer 仍运行在 Windows 宿主机
#
# 说明：
# - Docker Redis 通过宿主机 6380 映射到容器内 6379
# - 宿主机 FreshQuant / FQXTrade / QUANTAXIS 统一走 127.0.0.1:27027
# - Docker 容器内部仍应直连 fq_mongodb:27017，不要把宿主机映射端口写回容器内配置
# - 若后续切换到项目内 .venv，只需保留本文件中的 Mongo/Redis 配置，Python 路径改 supervisor 模板

FQ_PACK_DIR=D:/fqpack
FQ_DATA_DIR=D:/fqdata

FRESHQUANT_MONGODB__HOST=127.0.0.1
FRESHQUANT_MONGODB__PORT=27027
FRESHQUANT_MONGODB__DB=freshquant
FRESHQUANT_MEMORY__MONGODB__HOST=127.0.0.1
FRESHQUANT_MEMORY__MONGODB__PORT=27027
FRESHQUANT_MEMORY__MONGODB__DB=fq_memory
FRESHQUANT_MEMORY__ARTIFACT_ROOT=D:/fqpack/runtime/artifacts/memory
FRESHQUANT_MEMORY__REFERENCE_REF=origin/main
# 可选：显式覆盖 legacy QUANTAXIS Mongo URI
# MONGOURI=mongodb://127.0.0.1:27027

FRESHQUANT_REDIS__HOST=127.0.0.1
FRESHQUANT_REDIS__PORT=6380
FRESHQUANT_REDIS__DB=1

FRESHQUANT_TDX__HQ__ENDPOINT=http://127.0.0.1:15001

PYTHONUTF8=1
PYTHONLEGACYWINDOWSSTDIO=1
NO_PROXY=127.0.0.1,localhost
no_proxy=127.0.0.1,localhost
